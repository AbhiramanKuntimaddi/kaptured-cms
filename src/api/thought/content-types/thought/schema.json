{
  "kind": "collectionType",
  "collectionName": "thoughts",
  "info": {
    "singularName": "thought",
    "pluralName": "thoughts",
    "displayName": "Thought"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "Title",
      "required": true
    },
    "Image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Caption": {
      "type": "string",
      "required": true
    },
    "Description": {
      "type": "text",
      "required": true
    },
    "Date": {
      "type": "date",
      "required": true
    },
    "New": {
      "type": "boolean",
      "required": true,
      "default": true
    }
  }
}
